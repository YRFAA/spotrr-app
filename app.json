{
  "expo": {
    "name": "Spotrr",
    "slug": "spotrr",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/spotrr-logo.png",
    "scheme": "spotrr",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.spotrr.app",
      "buildNumber": "4",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Spotrr uses your location to find gym buddies near you",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.spotrr.app",
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/spotrr-logo.png",
        "backgroundColor": "#0c0c0c"
      },
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/spotrr-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/spotrr-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0c0c0c"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Spotrr uses your location to find gym buddies near you."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "35efcbbc-5298-4b31-adef-eaf8f91b13ea"
      },
      "router": {}
    },
    "owner": "spotrrapp"
  }
}
