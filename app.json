{
  "expo": {
    "name": "Spotrr",
    "slug": "spotrr",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/spotrr-logo.png",
    "scheme": "spotrr",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.emergent.spotrr",
      "buildNumber": "5",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Spotrr uses your location to find gym buddies near you",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.spotrr.app",
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/spotrr-logo.png",
        "backgroundColor": "#0c0c0c"
      },
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/spotrr-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/spotrr-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0c0c0c"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Spotrr uses your location to find gym buddies near you."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "targetSdkVersion": 35,
            "compileSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "kotlinVersion": "2.0.21",
            "packagingOptions": {
              "pickFirst": [
                "lib/arm64-v8a/libc++_shared.so",
                "lib/armeabi-v7a/libc++_shared.so",
                "lib/x86/libc++_shared.so",
                "lib/x86_64/libc++_shared.so"
              ]
            },
            "extraProguardRules": "-keep class com.spotrr.** { *; }"
          },
          "ios": {
            "deploymentTarget": "15.1",
            "newArchEnabled": true
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "35efcbbc-5298-4b31-adef-eaf8f91b13ea"
      },
      "router": {}
    },
    "owner": "spotrrapp"
  }
}
